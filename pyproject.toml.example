# Copiar como pyproject.toml en el repo nuevo y ajustar nombre/version.
# Crear proyecto: uv init --package waseller-crew --python 3.12

[project]
name = "waseller-crew"
version = "0.1.0"
description = "Microservicio CrewAI para shadow-compare con Waseller"
readme = "README.md"
requires-python = ">=3.11,<3.13"
dependencies = [
    "fastapi>=0.115.0",
    "uvicorn[standard]>=0.32.0",
    "pydantic>=2.10.0",
    # CrewAI: fijar versión acorde a la doc oficial al momento del scaffold
    "crewai>=0.86.0",
    "crewai-tools>=0.17.0",
]

[project.optional-dependencies]
dev = [
    "httpx>=0.28.0",
    "ruff>=0.8.0",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/crew_shadow_crewai"]

[tool.ruff]
line-length = 100
target-version = "py311"
