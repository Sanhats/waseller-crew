# API del LLM (ej. OpenAI — ver variables que espera CrewAI en tu versión).
# Valor en una sola línea, sin comillas ni prefijo "Bearer ". Railway: revisá que no haya espacio/salto al pegar.
OPENAI_API_KEY=
# Modelo CrewAI (default gpt-4o-mini). Ej.: gpt-4o-mini o openai/gpt-4o
OPENAI_MODEL_NAME=
# Solo si usás proxy/Azure compatible; si está mal, OpenAI devuelve 401. En Railway suele ir vacío.
OPENAI_BASE_URL=

# Producción: dejar vacío o false. Con 1/true el servicio usa stub (no llama al LLM).
USE_CREW_STUB=

# Logs más verbosos del crew (1/true/yes)
CREWAI_VERBOSE=

# Servidor
PORT=8080
LOG_LEVEL=info

# Recarga automática de uvicorn al cambiar código (solo desarrollo)
UVICORN_RELOAD=

# --- Contrato HTTP v1.1 (auth Bearer opcional) ---
# Mismo valor que LLM_SHADOW_COMPARE_SECRET en workers Waseller (si lo envían).
SHADOW_COMPARE_SECRET=
# Si true: exige Authorization: Bearer <SHADOW_COMPARE_SECRET>. Default: ausente/false (local/staging).
SHADOW_COMPARE_REQUIRE_AUTH=

# Directorio con tenant_prompts/<businessProfileSlug>.txt (opcional; default: ./tenant_prompts en la raíz del repo)
CREW_TENANT_PROMPTS_DIR=
